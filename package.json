{
  "name": "@synervoz/edgespeech",
  "version": "0.2.0",
  "description": "React Native library for on-device voice processing with Switchboard SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "ios/*.swift",
    "edgespeech.podspec",
    "expo-module.config.json",
    "scripts/postinstall.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postinstall": "node scripts/postinstall.js",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "keywords": [
    "react-native",
    "voice",
    "speech",
    "stt",
    "tts",
    "vad",
    "edgespeech",
    "whisper",
    "on-device"
  ],
  "author": "Thom Leigh",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/switchboard-sdk/EdgeSpeech#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:switchboard-sdk/EdgeSpeech.git"
  },
  "peerDependencies": {
    "expo": ">=51.0.0",
    "expo-modules-core": ">=2.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.74.0"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.76.0",
    "@react-native/eslint-config": "^0.76.0",
    "@react-native/metro-config": "^0.76.0",
    "@react-native/typescript-config": "^0.76.0",
    "@types/react": "~19.1.10",
    "@types/jest": "^29.5.0",
    "eslint": "^8.57.1",
    "expo": "~54.0.32",
    "expo-modules-core": ">=2.0.0",
    "jest": "^29.6.3",
    "prettier": "^2.8.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "typescript": "^5.0.4"
  },
  "codegenConfig": {
    "name": "SwitchboardVoiceSpecs",
    "type": "modules",
    "jsSrcsDir": "specs"
  },
  "engines": {
    "node": ">=18"
  }
}
