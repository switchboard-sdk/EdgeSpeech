{
  "name": "@synervoz/edgespeech",
  "version": "0.2.1",
  "description": "React Native library for on-device voice processing with Switchboard SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "ios/*.swift",
    "edgespeech.podspec",
    "expo-module.config.json",
    "scripts/postinstall.js",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "postinstall": "node scripts/postinstall.js",
    "test": "jest --verbose",
    "test:integration": "jest --config jest.integration.config.js",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "check": "tsc --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "keywords": [
    "react-native",
    "voice",
    "speech",
    "stt",
    "tts",
    "vad",
    "edgespeech",
    "whisper",
    "silero",
    "switchboard",
    "on-device"
  ],
  "author": "Thom Leigh",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://github.com/switchboard-sdk/EdgeSpeech#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:switchboard-sdk/EdgeSpeech.git"
  },
  "peerDependencies": {
    "expo": ">=51.0.0",
    "expo-modules-core": ">=2.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.74.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1062.0",
    "@react-native/babel-preset": "^0.76.0",
    "@react-native/eslint-config": "^0.85.2",
    "@react-native/metro-config": "^0.76.0",
    "@react-native/typescript-config": "^0.76.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "expo": "~54.0.32",
    "expo-modules-core": "~3.0.29",
    "jest": "^29.6.3",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0"
  },
  "overrides": {
    "eslint-plugin-ft-flow": {
      "eslint": "$eslint"
    }
  }
}
